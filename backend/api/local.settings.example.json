{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",

    // Azure Document Intelligence (Form Recognizer)
    "DI_ENDPOINT": "https://<your-doc-intel-resource>.cognitiveservices.azure.com/",
    "DI_KEY": "<your-doc-intel-key>",

    // OpenAI (for suggestLabels)
    "OPENAI_API_KEY": "<your-openai-key>",
    "OPENAI_API_VERSION": "2024-02-15-preview",
    "OPENAI_ENDPOINT": "https://api.openai.com/v1",
    "EMBEDDING_MODEL": "text-embedding-3-small",

    // Runtime semantic toggle in mappingEngine:
    // 1 = disable per-block runtime embedding calls
    // 0 or unset = enable runtime semantic matching
    "DISABLE_RUNTIME_EMBEDDINGS": "1",

    // Required for Functions App Model
    "FUNCTIONS_WORKER_RUNTIME": "node",
    "AzureWebJobsFeatureFlags": "EnableWorkerIndexing",

    // SWA local emulator flag
    "SWA_CLI_DEBUG": "true",

    // Azure Storage for saving mappings
    "AZURE_STORAGE_CONNECTION_STRING": "<your-storage-connection-string>"
  }
}
