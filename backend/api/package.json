{
  "name": "inchanted-api",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "build": "npm --prefix ../../shared run build && tsc -p tsconfig.json",
    "start": "func start",
    "test": "npm run build && node --test tests/*.test.js",
    "test:fixtures": "npm run build && node scripts/run-fixture-regression.js",
    "test:fixtures:update": "npm run build && node scripts/run-fixture-regression.js --update",
    "diag:mapping": "npm run build && node scripts/run-mapping-diagnostics.js",
    "diag:mapping:all": "npm run build && node scripts/run-mapping-diagnostics.js --all",
    "diag:root-cause": "npm run build && node scripts/run-root-cause-eval.js",
    "diag:load": "npm run build && node scripts/run-wave49-load-validation.js",
    "diag:geometry": "npm run build && node scripts/run-wave5-geometry-validation.js",
    "diag:geometry:integration": "npm run build && node scripts/run-wave5-geometry-integration.js",
    "diag:geometry:sprint2": "npm run build && node scripts/sprint2_geometry_regression_runner.js",
    "diag:category:sprint3": "npm run build && node scripts/sprint3_category_mode_validation_runner.js --mode sprint3_category_full",
    "diag:category:integration": "npm run build && node scripts/run-wave5-category-mode-integration.js",
    "diag:reflow:sprint4": "npm run build && node scripts/sprint4_reflow_validation_runner.js",
    "diag:reflow:integration": "npm run build && node scripts/run-wave5-reflow-integration.js",
    "diag:tuning:sprint5": "npm run build && node scripts/sprint5_tuning_validation_runner.js",
    "diag:tuning:integration": "npm run build && node scripts/run-wave5-tuning-integration.js",
    "diag:tuning:sprint5:fast": "npm run build && cross-env SPRINT5_TUNING_MODE=fast_deterministic node scripts/sprint5_tuning_validation_runner.js",
    "diag:tuning:sprint5:strict": "npm run build && cross-env SPRINT5_TUNING_MODE=strict_live_host_only node scripts/sprint5_tuning_validation_runner.js",
    "diag:tuning:integration:fast": "npm run build && cross-env SPRINT5_TUNING_MODE=fast_deterministic node scripts/run-wave5-tuning-integration.js",
    "diag:tuning:integration:strict": "npm run build && cross-env SPRINT5_TUNING_MODE=strict_live_host_only node scripts/run-wave5-tuning-integration.js",
    "gate:anchors": "npm run build && node scripts/run-anchor-regression-gate.js"
  },
  "dependencies": {
    "@azure/ai-form-recognizer": "^5.1.0",
    "@azure/functions": "^4.0.0",
    "@azure/storage-blob": "^12.31.0",
    "openai": "^4.0.0",
    "shared": "file:../../shared"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "azure-functions-core-tools": "^4.12.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.4.0"
  }
}
