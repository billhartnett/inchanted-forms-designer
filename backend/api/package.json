{
  "name": "inchanted-api",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && npm --prefix ../../shared run build && tsc -p tsconfig.json",
    "start:express": "node dist/server.js",
    "start": "npm run start:express",
    "test": "npm run build && node --test tests/*.test.js",
    "test:fixtures": "npm run build && node scripts/run-fixture-regression.js",
    "test:fixtures:update": "npm run build && node scripts/run-fixture-regression.js --update",
    "diag:mapping": "npm run build && node scripts/run-mapping-diagnostics.js",
    "diag:mapping:all": "npm run build && node scripts/run-mapping-diagnostics.js --all",
    "diag:wave8:anchors": "npm run build && node scripts/run-wave8-anchor-diagnostics.js",
    "diag:root-cause": "npm run build && node scripts/run-root-cause-eval.js",
    "diag:load": "npm run build && node scripts/run-wave49-load-validation.js",
    "diag:geometry": "npm run build && node scripts/run-wave5-geometry-validation.js",
    "diag:geometry:integration": "npm run build && node scripts/run-wave5-geometry-integration.js",
    "diag:geometry:sprint2": "npm run build && node scripts/sprint2_geometry_regression_runner.js",
    "diag:category:sprint3": "npm run build && node scripts/sprint3_category_mode_validation_runner.js --mode sprint3_category_full",
    "diag:category:integration": "npm run build && node scripts/run-wave5-category-mode-integration.js",
    "diag:reflow:sprint4": "npm run build && node scripts/sprint4_reflow_validation_runner.js",
    "diag:reflow:integration": "npm run build && node scripts/run-wave5-reflow-integration.js",
    "diag:tuning:sprint5": "npm run build && node scripts/sprint5_tuning_validation_runner.js",
    "diag:tuning:integration": "npm run build && node scripts/run-wave5-tuning-integration.js",
    "diag:tuning:sprint5:fast": "npm run build && cross-env SPRINT5_TUNING_MODE=fast_deterministic node scripts/sprint5_tuning_validation_runner.js",
    "diag:tuning:sprint5:strict": "npm run build && cross-env SPRINT5_TUNING_MODE=strict_live_host_only node scripts/sprint5_tuning_validation_runner.js",
    "diag:tuning:integration:fast": "npm run build && cross-env SPRINT5_TUNING_MODE=fast_deterministic node scripts/run-wave5-tuning-integration.js",
    "diag:tuning:integration:strict": "npm run build && cross-env SPRINT5_TUNING_MODE=strict_live_host_only node scripts/run-wave5-tuning-integration.js",
    "diag:replay:wave6": "npm run build && node scripts/wave6_replay_tuning_runner.js",
    "diag:replay:wave6:fast": "npm run build && cross-env WAVE6_REPLAY_MODE=fast_deterministic node scripts/wave6_replay_tuning_runner.js",
    "diag:replay:wave6:strict": "npm run build && cross-env WAVE6_REPLAY_MODE=strict_live_host_only node scripts/wave6_replay_tuning_runner.js",
    "diag:replay:integration:wave6": "npm run build && node scripts/wave6_replay_integration.js",
    "diag:replay:integration:wave6:fast": "npm run build && cross-env WAVE6_REPLAY_MODE=fast_deterministic node scripts/wave6_replay_integration.js",
    "diag:replay:integration:wave6:strict": "npm run build && cross-env WAVE6_REPLAY_MODE=strict_live_host_only node scripts/wave6_replay_integration.js",
    "diag:replay:phase2:application": "npm run build && node scripts/wave6_phase2_replay_application.js",
    "diag:replay:phase3:threshold:tightening": "npm run build && node scripts/wave6_phase3_threshold_tightening.js",
    "diag:replay:phase4:diagnostics:stabilization": "npm run build && node scripts/wave6_phase4_diagnostics_stabilization.js",
    "gate:wave7:phase1:livehost": "npm run build && node scripts/wave7_phase1_livehost_replay_validation.js",
    "gate:wave7:phase2:carrier:adapter": "npm run build && node scripts/wave7_phase2_carrier_adapter_tuning.js",
    "gate:wave7:phase3:production:readiness": "npm run build && node scripts/wave7_phase3_production_readiness_gating.js",
    "gate:wave8:phase1:performance:hardening": "npm run build && node scripts/wave8_phase1_performance_hardening.js",
    "gate:wave8:phase2:stability:hardening": "npm run build && node scripts/wave8_phase2_stability_hardening.js",
    "gate:wave8:exit:release:candidate": "npm run build && node scripts/wave8_exit_release_candidate_generation.js",
    "gate:release:deployment:rollout": "npm run build && node scripts/release_deployment_production_rollout.js",
    "gate:anchors": "npm run build && node scripts/run-anchor-regression-gate.js"
  },
  "dependencies": {
    "@azure/ai-form-recognizer": "^5.1.0",
    "@azure/functions": "^4.0.0",
    "@azure/storage-blob": "^12.31.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "inchanted-forms-designer": "file:../..",
    "openai": "^4.0.0",
    "shared": "file:../../shared"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.19.43",
    "cross-env": "^7.0.3",
    "typescript": "^5.4.0"
  }
}
