    <button sid="Save_BUTTON">
      <pecs:short_cut xfdl:compute="toggle(global.global.keypress, '', 'F2') == '1' ? (set('activated','on')) : ''"></pecs:short_cut>
      <type>save</type>
      <bgcolor>
        <ae>190</ae>
        <ae>0</ae>
        <ae>76</ae>
      </bgcolor>
      <justify>center</justify>
      <fontcolor>
        <ae compute="mouseover == 'on' ? 'yellow' : 'white'">yellow</ae>
      </fontcolor>
      <fontinfo>
        <ae>Helvetica</ae>
        <ae>7</ae>
        <ae>bold</ae>
      </fontinfo>
      <value>Save</value>
      <borderwidth>0</borderwidth>
