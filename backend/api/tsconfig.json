{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": ".",
    "rootDir": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "index.ts",
    "functions.ts",
    "extractText/**/*.ts",
    "suggestLabels/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "__blobstorage__",
    "__queuestorage__",
    "__azurite_db*"
  ]
}
